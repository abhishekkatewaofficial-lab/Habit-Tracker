rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Base rule: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // User data rule: Users can only read and write to their own top-level uid folder
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // All subcollections under /users/{userId} inherit this permission
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
